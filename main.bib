author = {Françoise Forges},
keywords = {Bayesian game, Commitment, Contract, Incentive compatibility, Interim individual rationality},
abstract = {The set of all Bayesian–Nash equilibrium payoffs that the players can achieve by making conditional commitments at the interim stage of a Bayesian game coincides with the set of all feasible, incentive compatible and interim individually rational payoffs of the Bayesian game. Furthermore, the various equilibrium payoffs, which are achieved by means of different commitment devices, are also the equilibrium payoffs of a universal, deterministic commitment game.}
}

