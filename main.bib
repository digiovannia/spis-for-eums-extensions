@article{binmorenorm,
 ISSN = {09324569},
 URL = {http://www.jstor.org/stable/40753015},
 abstract = {This paper seeks to close the gap between the models of man used by economists and sociologists. The problem of the evolution of social norms is identified with the equilibrium selection problem in game theory. Adopting such a view requires that sociologists be ready to regard social norms as being endogenously determined, and for economists to abandon the literature on refinements of Nash equilibrium in favor of an evolutionary approach. Even in simple situations like the Ultimatum Game, the consequences can be striking.},
 author = {Ken Binmore and Larry Samuelson},
 journal = {Journal of Institutional and Theoretical Economics (JITE) / Zeitschrift für die gesamte Staatswissenschaft},
 number = {1},
 pages = {45--63},
 publisher = {Mohr Siebeck GmbH & Co. KG},
 title = {An Economist's Perspective on the Evolution of Norms},
 volume = {150},
 year = {1994}
}



